<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>LitLink</string>
	<key>CFBundleName</key>
	<string>LitLink</string>
	<key>GEMINI_API_KEY</key>
	<string>$(GEMINI_API_KEY)</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>LitLink needs microphone access to listen to your reading and help you improve pronunciation.</string>
	<key>SUPABASE_URL</key>
	<string>$(SUPABASE_URL)</string>
	<key>SUPABASE_PUBLISHABLE_KEY</key>
	<string>$(SUPABASE_PUBLISHABLE_KEY)</string>
	<key>SUPABASE_ANON_KEY</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>LitLink uses speech recognition to verify that you&apos;re reading aloud and to provide pronunciation feedback.</string>
